      "notes": "Fresh and peeled"
    },
    {
      "name": "Vegetable Oil",
      "amount": "2 tablespoons",
      "notes": "For brushing skewers"
    },
    {
      "name": "Ginger",
      "amount": "2 inches",
      "notes": "Fresh, peeled and minced"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "Minced"
    },
    {
      "name": "Soy Sauce",
      "amount": "2 tablespoons",
      "notes": "Low sodium"
    },
    {
      "name": "Brown Sugar",
      "amount": "1 tablespoon",
      "notes": "For marinade"
    },
    {
      "name": "Lime Juice",
      "amount": "2 tablespoons",
      "notes": "Freshly squeezed"
    },
    {
      "name": "Chili Flakes",
      "amount": "1 teaspoon",
      "notes": "Optional, for some heat"
    },
    {
      "name": "Fresh Cilantro",
      "amount": "1/4 cup",
      "notes": "Chopped, for garnish"
    },
    {
      "name": "Skewers",
      "amount": "10-12",
      "notes": "For grilling"
    }
  ],
  "instructions": [
    "1. Preheat grill to medium-high heat.",
    "2. In a blender or food processor, combine ginger, garlic, soy sauce, brown sugar, and chili flakes (if using). Blend until smooth.",
    "3. Add lime juice and blend until combined.",
    "4. Place shrimp in a large bowl and pour marinade over them. Toss to coat.",
    "5. Thread shrimp onto skewers, leaving a small space between each shrimp.",
    "6. Brush vegetable oil onto the grill grates.",
    "7. Grill skewers for 2-3 minutes per side, or until shrimp are pink and cooked through.",
    "8. Garnish with chopped cilantro and serve immediately.",
    "9. Serve with a side of rice or noodles, if desired.",
    "10. Enjoy!"
  ],
