  "instructions": [
    "heat the olive oil in a large donabe over medium heat.",
    "add the chopped onion and cook until translucent, about 5 minutes.",
    "add the grated ginger, cumin, coriander, cayenne pepper, and paprika. cook for 1 minute.",
    "add the lardons-render and cook until browned, about 5 minutes.",
    "add the chopped chives, salt, and black pepper. stir to combine.",
    "add the water and bring to a boil.",
    "reduce the heat to low and simmer, covered, for 20 minutes.",
    "season with additional salt and pepper to taste.",
    "serve hot, garnished with additional chives if desired."
  ],
