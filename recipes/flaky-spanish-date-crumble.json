  "ingredients": [
    {
      "name": "2 cups Medjool dates",
      "amount": "",
      "notes": "pitted"
    },
    {
      "name": "1 cup all-purpose flour",
      "amount": ""
    },
    {
      "name": "1/4 cup granulated sugar",
      "amount": ""
    },
    {
      "name": "1/4 teaspoon salt",
      "amount": ""
    },
    {
      "name": "1/2 cup unsalted butter, softened",
      "amount": ""
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a large bowl, combine dates, flour, sugar, and salt.",
    "Add the softened butter to the date mixture and mix until well combined. The mixture will be crumbly.",
    "Transfer the mixture onto a baking sheet lined with parchment paper or a silpat.",
    "Bake for 20-25 minutes or until golden brown on top.",
    "Remove from oven and let cool before serving."
