  "instructions": [
    "heat the oil in a large skillet over medium-high heat",
    "add the onion and cook until softened, about 5 minutes",
    "add the garlic and cook for 1 minute",
    "add the mushrooms and cook until they release their liquid and start to brown, about 5 minutes",
    "add the spinach and cook until wilted",
    "stir in the cumin, paprika, salt, and black pepper",
    "add the mother sauce base and stir to combine",
    "add the udon noodles and stir to coat with the sauce",
    "cook for an additional 2-3 minutes or until the noodles are heated through",
    "taste and adjust the seasoning as needed",
    "serve hot, topped with feta cheese if desired"
  ],
