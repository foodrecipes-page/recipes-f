      "amount": "0.5 teaspoon",
      "notes": ""
    },
    {
      "name": "Lemon zest",
      "amount": "1 tablespoon",
      "notes": "zest of one lemon"
    },
    {
      "name": "Dried lavender buds",
      "amount": "2 teaspoons",
      "notes": "finely ground"
    },
    {
      "name": "White rum",
      "amount": "1 tablespoon",
      "notes": ""
    },
    {
      "name": "Agave syrup",
      "amount": "1 tablespoon",
      "notes": "optional for sweetness"
    },
    {
      "name": "Fresh mint leaves",
      "amount": "1 teaspoon",
      "notes": "finely chopped for garnish"
    }
  ],
  "instructions": [
    "Rinse jasmine rice under cold water until the water runs clear.",
    "In a saucepan, combine rice, water or broth, sea salt, lemon zest, and lavender buds. Bring to a gentle boil.",
    "Reduce heat to low, cover, and let simmer for 12 minutes while steam gently cooks the rice.",
    "Remove from heat, stir in rum and agave syrup.",
    "Cover and let sit for 5 minutes to allow flavors to meld.",
    "Serve hot, garnished with fresh mint leaves."
  ],
