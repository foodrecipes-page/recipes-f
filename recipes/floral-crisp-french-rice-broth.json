  "ingredients": [
    {
      "name": "Jasmine rice",
      "amount": "1 cup (uncooked)",
      "notes": "uncooked"
    },
    {
      "name": "Water or low‑sodium vegetable broth",
      "amount": "4 cups",
      "notes": ""
    },
    {
