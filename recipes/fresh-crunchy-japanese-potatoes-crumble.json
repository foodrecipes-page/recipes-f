  "title": "Fresh Crunchy Japanese Potatoes Crumble",
  "description": "A light yet indulgent Japanese potato crumble thats crisp on top, creamy inside, and FODMAP-friendly.",
  "cuisine": "Japanese",
  "diet": [
    "vegetarian"
  ],
