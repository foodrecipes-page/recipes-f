  "ingredients": [
    {
      "name": "pappardelle pasta",
      "amount": "200g"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "garlic cloves",
      "amount": "3, minced"
    },
    {
      "name": "onion",
      "amount": "1 medium, finely chopped"
    },
    {
      "name": "leeks",
      "amount": "2 stalks, thinly sliced"
    },
    {
      "name": "bell pepper",
      "amount": "1/4 large, diced"
    },
    {
      "name": "basil leaves",
      "amount": "3-5 fresh, finely torn"
    },
    {
      "name": "thyme sprigs",
      "amount": "few"
    },
    {
      "name": "butter",
      "amount": "2 tbsp (optional)"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat olive oil in a skillet over medium heat. Add butter if using, then sauté garlic and onion until translucent.",
    "Add bell pepper and leeks to the skillet; cook for about 5 minutes or until soft.",
    "Toss in basil leaves and thyme sprigs. Season with salt and pepper according to taste.",
    "Gently poach pappardelle pasta in boiling water according to package instructions, then drain well.",
    "Stir-fry the pasta by tossing it with the herb mixture for about 2 minutes until heated through.",
    "Serve hot as a main course or side dish."
  ],
