{
  "title": "Floral Dutch Pasta Stir-fry",
  "description": "A floral, fluffy Dutch dish featuring diabetic-friendly pappardelle pasta in a cozy stir-fry, infused with aromatic herbs and gently poached vegetables.",
  "cuisine": "Dutch",
  "diet": [
    "diabetic-friendly"
  ],
