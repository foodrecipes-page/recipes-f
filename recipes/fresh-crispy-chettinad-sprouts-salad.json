{
  "title": "Fresh Crispy Chettinad Sprouts Salad",
  "description": "A monsooninspired, airfried sprout salad packed with fiery Chettinad flavors, fresh herbs and a zesty ginger paste dressing.",
  "cuisine": "Indian",
  "diet": [
    "vegetarian",
    "vegan"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "Mixed raw sprouts (moong & green gram)",
      "amount": "2 cups",
      "notes": "wash and rinse thoroughly before use"
    },
    {
      "name": "Red bell pepper",
      "amount": "1/2 medium",
      "notes": "diced into bite\u2011sized pieces"
    },
    {
      "name": "Yellow onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "Unsalted dry roasted coconut flakes",
      "amount": "2 tbsp",
      "notes": "lightly toasted before adding"
    },
    {
      "name": "Fresh mint leaves",
      "amount": "2 tbsp",
      "notes": "finely chopped"
    },
    {
      "name": "Fresh cilantro",
      "amount": "2 tbsp",
      "notes": "finely chopped"
    },
    {
      "name": "Lemon juice",
      "amount": "1 tbsp",
      "notes": "freshly squeezed"
    },
    {
      "name": "Ginger paste",
      "amount": "1 tsp",
      "notes": "homemade or store\u2011bought"
    },
    {
      "name": "Red chili powder",
      "amount": "1/2 tsp",
      "notes": "adjust to taste"
    },
    {
      "name": "Cumin seeds",
      "amount": "1/4 tsp",
      "notes": "toasted for flavor"
    },
    {
      "name": "Black pepper powder",
      "amount": "1/4 tsp",
      "notes": "freshly ground"
    },
    {
      "name": "Salt",
      "amount": "to taste",
      "notes": "use sea salt or kosher"
    },
    {
      "name": "Mustard seeds",
      "amount": "1/2 tsp",
      "notes": "to be tossed in the air\u2011fry"
    }
  ],
  "instructions": [
    "Preheat the air fryer to 200\u202f\u00b0C (400\u202f\u00b0F).",
    "Lightly toss the sliced onion and bell pepper with 1 tbsp oil, cumin seeds, mustard seeds, salt and pepper. Air\u2011fry for 5\u20136\u202fminutes until crisp, stirring halfway. Set aside to cool slightly.",
    "In a large bowl, combine the raw sprouts, cooled air\u2011fried veggies, roasted coconut flakes, mint and cilantro.",
    "Whisk together lemon juice, ginger paste, red chili powder and a dash of salt to make the dressing. Pour over the salad and toss gently to coat.",
    "Sprinkle the toasted coconut flakes and a sprinkling of extra black pepper on top. Serve immediately for maximum crunch."
  ],
