{
  "title": "Floral Creamy Arab Chicken Soup",
  "description": "A soothing, fragrant chicken soup with subtle rose essence, creamy coconut milk, and aromatic herbs, perfect for a sick day or comforting Middle Eastern palate.",
  "cuisine": "Middle Eastern",
  "diet": [
    "paleo"
  ],
  "meal": "dinner",
  "ingredients": [
