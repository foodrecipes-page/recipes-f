    },
    {
      "name": "Egg, beaten (for egg wash)",
      "amount": "1",
      "notes": ""
    },
    {
      "name": "Yogurt",
      "amount": "1 cup, plain, low-fat",
      "notes": "for serving (optional)"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "Roll out the flaky pastry dough to a thickness of 1/8 inch (3 mm).",
    "Cut out circles of dough using a cookie cutter or the rim of a glass.",
    "Place a tablespoon of crumbled summer savory and a tablespoon of bhuna mixture in the center of each circle.",
    "Brush the edges of the pastry with the beaten egg for a golden glaze.",
    "Fold the pastry in half to form a triangle or a square, pressing the edges to seal.",
    "Brush the tops of the pastries with ghee or vegetable oil.",
    "Bake for 25-30 minutes, or until golden brown.",
    "Serve warm or at room temperature, with a dollop of yogurt if desired."
  ],
