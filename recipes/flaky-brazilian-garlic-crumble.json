{
  "title": "Flaky Brazilian Garlic Crumble",
  "description": "A keto-friendly, broiled dish that combines the savory and aromatic flavors of pistachio paste with fresh garlic for a date-night treat.",
  "cuisine": "Brazilian",
  "diet": [
    "keto"
  ],
