  "ingredients": [
    {
      "name": "Serrano ham",
      "amount": "6 slices",
      "notes": "thinly sliced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "orange juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a large skillet, heat the olive oil over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the Serrano ham slices and cook until they are crispy.",
    "In a small bowl, whisk together the lemon juice, orange juice, paprika, salt, and black pepper.",
    "Pour the juice mixture over the Serrano ham and onions.",
    "Transfer the mixture to a scallop shell and bake for 10 minutes.",
    "Garnish with chopped fresh parsley and serve hot."
  ],
