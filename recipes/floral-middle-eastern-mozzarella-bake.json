{
  "title": "Floral Middle Eastern Mozzarella Bake",
  "description": "A light, fragrant plantbased bake featuring floral rose water, sweet date syrup, and creamy vegan mozzarella, perfect for a date night.",
  "cuisine": "Middle Eastern",
  "diet": [
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Plant\u2011based mozzarella",
      "amount": "200g, sliced",
      "notes": "vegan alternative"
    },
    {
      "name": "Fresh spinach",
      "amount": "200g, chopped",
      "notes": "washed"
    },
    {
      "name": "Red bell pepper",
      "amount": "1 medium, diced"
    },
    {
      "name": "Cooked chickpeas",
      "amount": "1 cup (165g), drained"
    },
    {
      "name": "Couscous",
      "amount": "50g, dry",
      "notes": "quick\u2011cook"
    },
    {
      "name": "Date syrup",
      "amount": "2 tbsp (30g)",
      "notes": "sweetener"
    },
    {
      "name": "Rose water",
      "amount": "1 tsp",
      "notes": "floral aroma"
    },
    {
      "name": "Olive oil",
      "amount": "1 tbsp",
      "notes": "for drizzling"
    },
    {
      "name": "Lemon zest",
      "amount": "1 tbsp",
      "notes": "freshness"
    },
    {
      "name": "Garlic",
      "amount": "2 cloves, minced",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat oven to 190\u00b0C (375\u00b0F).",
    "In a saucepan, bring 1 cup water to boil, add couscous, cover, and let steam 5 minutes; fluff with a fork.",
    "In a large bowl, combine spinach, bell pepper, chickpeas, and couscous.",
    "Add date syrup, rose water, lemon zest, garlic, olive oil, and salt to taste; toss to coat.",
    "Spread the mixture evenly in an 8\u00d78\u2011inch baking dish.",
    "Arrange sliced vegan mozzarella on top.",
    "Bake for 20 minutes until mozzarella is melted and edges are lightly golden.",
    "Remove from oven and let rest 5 minutes.",
    "Sprinkle extra lemon zest and fresh herbs if desired.",
    "Serve warm, accompanied by fresh flatbread or a simple green salad."
  ],
