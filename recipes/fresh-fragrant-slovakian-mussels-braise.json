  "instructions": [
    "Rinse the mussels under cold water and discard any broken shells.",
    "Heat the olive oil in a claypot over medium heat.",
    "Add the minced garlic and cook until fragrant.",
    "Add the white wine and bring to a simmer.",
    "Add the mussels, bay leaves, salt, and black pepper.",
    "Cover the claypot and cook for 8 minutes, or until the mussels are cooked through.",
    "Remove the claypot from the heat and stir in the chopped parsley.",
