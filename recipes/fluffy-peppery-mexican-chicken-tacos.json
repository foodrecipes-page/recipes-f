      "name": "boneless chicken breasts",
      "amount": "1 1/2 pounds",
      "notes": "cut into small pieces"
    },
    {
      "name": "grape juice",
      "amount": "1 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "smoked paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
