    },
    {
      "name": "Olive Oil",
      "amount": "2 tbsp"
    },
    {
      "name": "Raw Paprika",
      "amount": "1 tsp"
    },
    {
      "name": "Garlic Powder",
      "amount": "1/2 tsp"
    },
    {
      "name": "Thyme Leaves (fresh)",
      "amount": "3-4 leaves"
    },
    {
      "name": "Cumin Seeds",
      "amount": "1 pinch"
    },
    {
      "name": "Turmeric Powder",
      "amount": "1/2 tsp"
    },
    {
      "name": "Oregano, Dried (optional)",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Mix beer with olive oil and set aside for fermentation.",
    "In a food processor or blender, combine all ingredients except the last two. Blend until well combined but retain some texture for a crumble effect.",
    "Transfer mixture to an oven-safe dish. Bake at 180°C (350°F) for 20 minutes, flip and bake another 10-15 minutes or until golden brown and crisp on top.",
    "Sprinkle with dried oregano if using before serving hot."
