    },
    {
      "name": "Sliced fresh bamboo skewers (1 dozen)",
      "amount": "1",
      "notes": "pre-soaked in water for 30 minutes"
    },
    {
      "name": "Robata-grill oil (1/4 cup)",
      "amount": "1/4",
      "notes": "such as peanut or vegetable oil"
