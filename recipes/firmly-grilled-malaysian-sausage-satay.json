      "amount": "1/4",
      "notes": "optional"
    },
    {
      "name": "Honey (2 tbsp)",
      "amount": "2",
      "notes": "for marinade"
    },
    {
      "name": "Lime juice (2 tbsp)",
      "amount": "2",
      "notes": "for marinade"
    },
    {
