{
  "title": "Floral Chewy Venezuelan Chicken Bowl",
  "description": "A fragrant, coconut‑infused chicken bowl with a chewy texture and a burst of floral lime‑citrus notes, perfect for a date night.",
  "cuisine": "Venezuelan",
  "diet": [
    "gluten-free",
    "nut-free",
