  "ingredients": [
    {
      "name": "boneless skinless chicken thighs",
      "amount": "4",
      "notes": "about 200 g each"
    },
    {
      "name": "unsweetened coconut milk",
      "amount": "1 cup",
      "notes": "240 ml"
    },
    {
      "name": "lime juice",
      "amount": "1 tablespoon",
      "notes": "freshly squeezed"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "ground coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "sea salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/8 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "cooked white rice",
      "amount": "2 cups"
    },
    {
      "name": "diced mango",
      "amount": "1/2 cup"
    },
    {
      "name": "diced red bell pepper",
      "amount": "1/2 cup"
    }
  ],
  "instructions": [
    "Season the chicken thighs with salt, pepper, cumin, smoked paprika, and ground coriander.",
    "Vacuum‑seal the seasoned chicken in a bag with the lime juice and coconut milk.",
    "Sous‑vide the sealed chicken at 65 °C (149 °F) for 90 minutes to achieve a tender, chewy texture.",
    "Remove the chicken from the bag, pat dry, and sear in a hot skillet with olive oil for 1–2 minutes on each side to develop a caramelized crust.",
    "Slice the chicken into bite‑sized strips.",
    "Warm the cooked rice and arrange it in a bowl.",
    "Top the rice with the sliced chicken, diced mango, and diced red bell pepper.",
    "Garnish with fresh cilantro and a squeeze of lime if desired.",
    "Serve immediately for a fresh, floral experience."
  ],
