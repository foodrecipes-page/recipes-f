      "name": "samphire",
      "amount": "1 pound",
      "notes": "rinsed and drained"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "berbere spice",
      "amount": "2 teaspoons"
    },
    {
      "name": "vegetable oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the oil in a large skillet over medium-high heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the samphire and cook until it is tender, about 5 minutes.",
    "Add the berbere spice, salt, and black pepper, and stir to combine.",
    "Squeeze the lemon juice over the top and stir to combine.",
    "Reduce the heat to low and simmer for 2 minutes.",
    "Serve the azifa hot, garnished with chopped fresh herbs if desired."
  ],
