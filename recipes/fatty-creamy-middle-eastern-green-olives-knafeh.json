      "amount": "1 package",
      "notes": "thawed"
    },
    {
      "name": "unsalted butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "granulated sweetener",
      "amount": "1/2 cup",
      "notes": "sugar substitute"
    },
    {
      "name": "large eggs",
      "amount": "2",
      "notes": "beaten"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon",
      "notes": "pure"
    },
    {
      "name": "chopped pistachios",
      "amount": "1/4 cup",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees Fahrenheit.",
    "In a large mixing bowl, combine the softened cream cheese, green olives, and granulated sweetener, mixing until smooth.",
    "Unroll the phyllo dough and cut it into 4 equal pieces.",
    "Layer the phyllo dough in a baking dish, brushing each layer with melted butter.",
    "Pour the cream cheese mixture over the phyllo dough.",
    "Top with beaten eggs and vanilla extract.",
    "Sprinkle chopped pistachios on top, if using.",
    "Bake for 35 minutes, or until the top is golden brown.",
    "Remove from the oven and let cool completely before serving."
  ],
