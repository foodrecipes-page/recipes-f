      "name": "2 cups jasmine rice",
      "amount": "cup",
      "notes": "Rinsed and drained"
    },
    {
      "name": "1/4 cup vegetable oil",
      "amount": "cup"
    },
    {
      "name": "1/2 onion, finely chopped",
      "amount": "1/2 cup"
    },
    {
      "name": "8 cloves garlic, minced",
      "amount": "cloves"
    },
    {
      "name": "1 can (8 oz) tomato ketchup",
      "amount": "can"
    },
    {
      "name": "100g egg whites",
      "amount": "100 grams",
      "notes": "For low-carb option"
    },
    {
      "name": "2 tablespoons soy sauce",
      "amount": "tablespoons"
    },
    {
      "name": "1 tablespoon sugar (optional for sweetness)",
      "amount": "tablespoon"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a large skillet over medium heat.",
    "Add the chopped onion and garlic, cooking until translucent.",
    "Stir in the tomato ketchup and soy sauce, mixing well to combine.",
    "Fold in the egg whites (or any extra protein of choice) into the sauce mixture.",
    "Gradually add the rice, tossing constantly to coat evenly with the sauce.",
    "Cook for 2-3 minutes until heated through. Season with salt if desired.",
    "Serve hot as a meal."
