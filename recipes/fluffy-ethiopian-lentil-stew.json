      "amount": "1 tablespoon"
    },
    {
      "name": "berbere spice",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat oil in a large pot over medium heat.",
    "Add the chopped onion and cook until softened.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the French lentils, ferment-jang, vegetable broth, tomato paste, and berbere spice.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer.",
    "Cook for 30 minutes or until the lentils are tender.",
    "Season with salt and pepper to taste.",
    "Serve hot over injera bread or with a side of steamed vegetables."
  ],
