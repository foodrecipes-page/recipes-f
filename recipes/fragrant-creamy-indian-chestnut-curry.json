{
  "title": "Fragrant Creamy Indian Chestnut Curry",
  "description": "Rich and creamy Chettinad dish featuring cooked chestnut and nuka-pickle, perfect for a Jain-friendly brunch",
  "cuisine": "Indian",
  "diet": [
    "vegetarian",
    "jain"
  ],
