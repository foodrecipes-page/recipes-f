      "name": "jumbo shrimp",
      "amount": "1 pound",
      "notes": "peeled and deveined"
    },
    {
      "name": "pickle relish",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "dill",
      "amount": "1/4 cup",
      "notes": "chopped fresh"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "pepper",
      "amount": "to taste"
    },
    {
      "name": "wooden skewers",
      "amount": "10-12",
      "notes": "soaked in water for 30 minutes"
    }
  ],
  "instructions": [
    "Preheat grill to medium-high heat.",
    "In a large bowl, whisk together lemon juice, olive oil, garlic, salt, and pepper.",
    "Add the shrimp to the bowl and toss to coat with the marinade.",
    "Thread the marinated shrimp onto the soaked skewers, leaving a small space between each shrimp.",
    "Grill the skewers for 2-3 minutes per side, or until the shrimp are pink and cooked through.",
    "While the shrimp are cooking, mix the pickle relish and chopped dill in a small bowl.",
    "Once the shrimp are done, brush them with the pickle relish mixture.",
    "Serve the skewers hot, garnished with additional dill if desired."
  ],
