{
  "title": "Fresh Norwegian Shrimp Skewers",
  "description": "A fresh and crunchy Norwegian dish featuring jumbo shrimp, perfect for a crowd. This pescatarian-friendly recipe is easy to make and packed with flavor.",
  "cuisine": "Norwegian",
  "diet": [
    "pescatarian"
  ],
