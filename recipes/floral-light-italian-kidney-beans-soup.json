      "name": "olive oil",
      "amount": "1 tbsp"
    },
    {
      "name": "onion, diced",
      "amount": "1 medium (about 150 g)"
    },
    {
      "name": "garlic cloves, minced",
      "amount": "2 (about 6 g)"
    },
    {
      "name": "carrot, diced",
      "amount": "1 cup (about 120 g)"
    },
    {
      "name": "celery stalk, diced",
      "amount": "1 cup (about 120 g)"
    },
    {
      "name": "red kidney beans, cooked or canned, drained",
      "amount": "2 cups (about 360 g)"
    },
    {
      "name": "diced tomatoes, canned",
      "amount": "1 cup (240 g)"
    },
    {
      "name": "vegetable broth",
      "amount": "4 cups (960 ml)",
      "notes": "use low‑sodium"
    },
    {
      "name": "fresh basil, chopped",
      "amount": "1/4 cup (6 g)"
    },
    {
      "name": "fresh parsley, chopped",
      "amount": "2 tbsp (10 g)"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "lemon juice",
      "amount": "1 tbsp",
      "notes": "optional, for brightness"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pot over medium heat.",
    "Add the diced onion and sauté until translucent, about 4 minutes.",
    "Stir in the minced garlic, diced carrot, and celery; cook for another 3 minutes.",
    "Add the kidney beans, diced tomatoes, and vegetable broth; bring to a gentle boil.",
    "Reduce heat to a simmer, cover, and let cook for 15 minutes to meld flavors.",
    "Season with salt and black pepper to taste.",
    "Just before serving, stir in fresh basil and parsley; adjust seasoning if needed.",
    "Serve hot, optionally garnished with a squeeze of lemon juice."
  ],
