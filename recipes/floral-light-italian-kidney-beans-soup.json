{
  "title": "Floral Light Italian Kidney Bean Soup",
  "description": "A fragrant, dairy‑free Italian-inspired soup bursting with herbs, kidney beans, and tomato, perfect for a quick kid‑friendly lunch.",
  "cuisine": "Italian",
  "diet": [
    "vegetarian",
    "dairy-free",
