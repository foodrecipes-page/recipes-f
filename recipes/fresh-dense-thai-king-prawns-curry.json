{
  "title": "Fresh Dense Thai King Prawn Curry",
  "description": "A nourishing Thai curry that combines succulent king prawns with a creamy coconut base, perfect for a quick high-protein meal when feeling under the weather.",
  "cuisine": "Thai",
  "diet": [
    "high-protein"
  ],
