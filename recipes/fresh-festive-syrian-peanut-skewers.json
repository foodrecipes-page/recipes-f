{
  "title": "Fresh Festive Syrian Peanut Skewers",
  "description": "A fresh and dense Syrian dish featuring peanut butter, perfect for a festive occasion, and can be made on a yakimono grill in a Buddhist temple friendly environment.",
  "cuisine": "Syrian",
  "diet": [
    "vegetarian",
    "vegan"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "peanut butter",
      "amount": "1 cup",
      "notes": "creamy"
    },
    {
      "name": "chickpeas",
      "amount": "1 can",
      "notes": "drained and rinsed"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "bamboo skewers",
      "amount": "20",
      "notes": "soaked in water for 30 minutes"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the yakimono grill to medium high heat.",
    "In a large bowl, whisk together peanut butter, garlic, lemon juice, olive oil, paprika, salt, and black pepper.",
    "Add the chickpeas to the bowl and stir until they are well coated with the peanut butter mixture.",
    "Thread the chickpeas onto the bamboo skewers, leaving a small space between each chickpea.",
    "Brush the grill with olive oil to prevent sticking.",
    "Grill the skewers for 10 minutes, turning occasionally, until they are lightly browned.",
    "Serve the skewers hot, garnished with chopped fresh parsley.",
    "Repeat with the remaining ingredients."
  ],
