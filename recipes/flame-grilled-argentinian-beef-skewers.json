{
  "title": "Flame Grilled Argentinian Beef Skewers",
  "description": "Charred and aerated solo dinner dish featuring palm sugar and nam tan pip, simmered to perfection in a keto friendly recipe",
  "cuisine": "Argentinian",
  "diet": [
    "keto",
    "low-carb"
  ],
