  "ingredients": [
    {
      "name": "beef strips",
      "amount": "1 pound",
      "notes": "grass fed"
    },
    {
      "name": "palm sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "nam tan pip",
      "amount": "1 tablespoon"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "lemongrass",
      "amount": "2 stalks",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat the grill to medium high heat",
    "In a large bowl whisk together palm sugar, nam tan pip, garlic powder, salt, and black pepper",
    "Add the beef strips to the bowl and toss to coat evenly",
    "Thread the beef strips onto skewers leaving a small space between each piece",
    "Brush the grill with olive oil to prevent sticking",
    "Grill the skewers for 8 minutes per side or until charred",
    "Let the skewers rest for 5 minutes before serving",
    "Garnish with lemongrass if desired",
    "Serve immediately"
  ],
