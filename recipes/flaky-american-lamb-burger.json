  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "200g",
      "notes": "halal certified, cut into 1cm cubes"
    },
    {
      "name": "spicy paprika",
      "amount": "1 tsp",
      "notes": "adjust to taste for heat"
    },
    {
      "name": "oregano",
      "amount": "1 tsp",
      "notes": "dried oregano for authentic flavor"
    },
    {
      "name": "garlic powder",
      "amount": "1/2 tsp",
      "notes": "adds depth without raw garlic"
    },
    {
      "name": "baking powder",
      "amount": "1/4 tsp",
      "notes": "for flakiness"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp",
      "notes": "freshly ground"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp",
      "notes": "for cooking"
    }
  ],
  "instructions": [
    "In a bowl, mix lamb cubes with spicy paprika, oregano, garlic powder, baking powder, salt, and black pepper until well combined.",
    "Heat olive oil in a skillet over medium heat (about 180°C/350°F).",
    "Add lamb cubes in a single layer to the skillet; cook for 5-7 minutes until browned and tender.",
    "Remove from heat and let rest for 2 minutes before serving."
  ],
