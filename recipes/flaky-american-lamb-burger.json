{
  "title": "Flaky American Lamb Burger",
  "description": "A spicy, flaky burger with a hint of oregano, braise-cooked to perfection, and designed to be a hangover cure. Halal-friendly and satisfying.",
  "cuisine": "american",
  "diet": [
    "halal",
    "vegetarian-friendly"
  ],
