{
  "title": "Floral Indulgent Malaysian Coconut Crumble",
  "description": "A sweet, dairy‑free crumble that marries fragrant chives and edible hibiscus with a rich coconut base, perfect for a fragrant dessert.",
  "cuisine": "Malaysian",
  "diet": [
    "dairy-free",
    "vegan",
    "gluten-free"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "coconut flour",
      "amount": "1 cup (120g)",
      "notes": "sifted"
    },
    {
      "name": "coconut sugar",
      "amount": "1/4 cup (50g)",
      "notes": "lightly packed"
    },
    {
      "name": "coconut oil",
      "amount": "2 tbsp (28g)",
      "notes": "melted"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp",
      "notes": ""
    },
    {
      "name": "sea salt",
      "amount": "1/4 tsp",
      "notes": ""
    },
    {
      "name": "fresh chives",
      "amount": "2 tbsp, finely chopped",
      "notes": "adds floral note"
    },
    {
      "name": "diced mango",
      "amount": "1/2 cup (75g)",
      "notes": "fresh or frozen"
    },
    {
      "name": "shredded unsweetened coconut",
      "amount": "1/4 cup (30g)",
      "notes": "to toast lightly later"
    },
    {
      "name": "edible hibiscus petals",
      "amount": "1 tbsp (10g)",
      "notes": "dried"
    },
    {
      "name": "lemon zest",
      "amount": "1 tbsp",
      "notes": "adds brightness"
    },
    {
      "name": "coconut milk",
      "amount": "1/2 cup (120ml)",
      "notes": "for a silky top"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a bowl, whisk together coconut flour, coconut sugar, salt, vanilla, and chives until well blended.",
    "Add melted coconut oil and stir until the mixture resembles coarse crumbs.",
    "Gently fold in diced mango, shredded coconut, hibiscus petals, and lemon zest.",
    "Transfer the mixture to a 9‑inch round baking dish, smoothing the top.",
    "Pour coconut milk over the crumble, spreading evenly.",
    "Bake for 25‑30 minutes, or until the top is golden and the milk is thickened.",
    "Let it cool for 10 minutes before serving. Enjoy the fragrant, indulgent crumble!"
  ],
