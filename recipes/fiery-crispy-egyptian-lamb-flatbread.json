      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into small pieces"
    },
    {
      "name": "white bread",
      "amount": "4 slices"
    },
    {
      "name": "onion",
      "amount": "1 medium"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
