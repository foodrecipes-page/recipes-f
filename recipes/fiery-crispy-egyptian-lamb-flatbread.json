      "amount": "1 teaspoon"
    },
    {
      "name": "coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the olive oil in a wok over medium-high heat.",
    "Add the lamb pieces and cook until browned on all sides.",
    "Add the onion, garlic, and ginger to the wok and cook until the onion is translucent.",
    "Add the cumin, coriander, cayenne pepper, and salt to the wok and stir to combine.",
    "Add 1 cup of water to the wok and bring to a boil.",
    "Reduce the heat to low and simmer for 10 minutes.",
    "Meanwhile, toast the white bread slices until crispy.",
    "Assemble the flatbread by placing the lamb mixture on top of the toasted bread.",
    "Serve hot and enjoy."
  ],
