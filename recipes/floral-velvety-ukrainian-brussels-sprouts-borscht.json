{
  "title": "Floral Velvety Ukrainian Brussels Sprouts Borscht",
  "description": "A paleo-friendly twist on the classic Ukrainian beet-based borscht, this recipe incorporates Brussels sprouts for a delightful and nutritious twist.",
  "cuisine": "Ukrainian",
  "diet": [
    "paleo",
