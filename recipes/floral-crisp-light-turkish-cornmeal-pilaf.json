      "name": "white cornmeal",
      "amount": "1 1/4 cups"
    },
    {
      "name": "water",
      "amount": "2 3/4 cups"
    },
    {
      "name": "unsalted chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion, finely chopped",
      "amount": "1 medium",
