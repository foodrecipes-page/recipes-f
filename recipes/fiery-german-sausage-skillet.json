      "name": "German sausage",
      "amount": "1 pound",
      "notes": "preferably knockwurst or bratwurst"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "sliced"
    },
    {
      "name": "bell pepper",
      "amount": "1 large",
      "notes": "sliced"
    },
    {
      "name": "parmesan cheese",
      "amount": "1 cup",
      "notes": "shredded"
    },
    {
      "name": "dashi extract",
      "amount": "2 teaspoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "hot sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large cast-iron skillet over medium-high heat",
    "Add the sliced onion and cook until it starts to brown, about 5 minutes",
    "Add the sliced bell pepper and cook until it starts to soften, about 3 minutes",
    "Add the German sausage and cook until browned on all sides, about 5 minutes",
    "Add the minced garlic and cook for 1 minute, until fragrant",
    "Add the dashi extract, hot sauce, salt, and black pepper, and stir to combine",
    "Reduce heat to medium-low and simmer for 10 minutes, until the sausage is cooked through",
    "Stir in the shredded parmesan cheese until melted and gooey",
    "Serve hot, garnished with chopped fresh parsley if desired"
  ],
