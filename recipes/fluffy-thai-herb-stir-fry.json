{
  "title": "Fluffy Thai Herb Stir-fry",
  "description": "A crowd-pleaser Thai dish featuring unsweetened coconut milk, packed with herbs and a touch of Mediterranean flair to make it mediterranean-friendly.",
  "cuisine": "Thai",
  "diet": null,
  "meal": "lunch",
  "ingredients": [
    {
      "name": "1 tablespoon olive oil",
      "amount": "tbsp"
    },
    {
      "name": "1 small onion, finely chopped",
      "amount": "medium"
    },
    {
      "name": "3 cloves garlic, minced",
      "amount": "cloves"
    },
    {
      "name": "1 cup fresh Thai basil leaves",
      "amount": "cup"
    },
    {
      "name": "1/2 cup fresh cilantro leaves",
      "amount": "cup"
    },
    {
      "name": "1/4 cup shredded green chili peppers (optional)",
      "amount": "tbsp"
    },
    {
      "name": "1 can unsweetened coconut milk (about 500ml)",
      "amount": "can"
    },
    {
      "name": "1/2 teaspoon turmeric powder",
      "amount": "tsp"
    },
    {
      "name": "Salt to taste",
      "amount": ""
    },
    {
      "name": "1/4 cup water",
      "amount": "cup"
    },
    {
      "name": "Pinch of cayenne pepper (optional)",
      "amount": ""
    }
  ],
  "instructions": [
    "In a large skillet, heat the olive oil over medium-high heat.",
    "Add the chopped onion and garlic. Sauté until translucent, about 5 minutes.",
    "Stir in Thai basil leaves, cilantro, green chili peppers, turmeric powder, salt, and water. Stir well to combine all ingredients.",
    "Pour in the coconut milk and let it simmer for about 10-12 minutes or until thickened, stirring occasionally.",
    "If desired, add a pinch of cayenne pepper for extra heat.",
    "Serve hot as a side dish with steamed rice or noodles."
  ],
