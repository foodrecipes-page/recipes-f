    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat a large skillet over medium heat and render the lardons until crispy",
    "Remove the lardons from the skillet and set aside",
    "Add the chopped onion to the skillet and cook until softened",
    "Add the minced garlic to the skillet and cook for 1 minute",
    "Add the diced apples to the skillet and cook until they start to soften",
    "Add the chicken broth, salt, and pepper to the skillet and bring to a boil",
    "Add the white rice to the skillet and stir to combine",
    "Reduce the heat to low, cover, and simmer for 20 minutes",
    "Fluff the pilaf with a fork and stir in the chopped parsley and crispy lardons"
  ],
