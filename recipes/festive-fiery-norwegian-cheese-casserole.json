  "ingredients": [
    {
      "name": "Norwegian cheese",
      "amount": "1 cup shredded",
      "notes": "fermented"
    },
    {
      "name": "enchilada sauce",
      "amount": "1 cup"
    },
    {
      "name": "confit-tomato",
      "amount": "1 cup diced"
    },
    {
      "name": "onion",
      "amount": "1 medium diced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large skillet, heat the olive oil over medium heat.",
    "Add the diced onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "In a large bowl, combine the cooked onion and garlic, shredded cheese, enchilada sauce, confit-tomato, salt, and black pepper.",
    "Mix well to combine.",
    "Transfer the mixture to a 9x13 inch baking dish.",
    "Bake for 25 minutes, or until the cheese is melted and bubbly."
  ],
