      "amount": "4 slices"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a pan over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Stir in the berbere spice and cook for 1 minute.",
    "Add the mashed black beans, lemon juice, and salt, and stir well.",
    "Reduce the heat to low and simmer the mixture for 10 minutes.",
    "Toast the whole wheat bread until it is lightly browned.",
    "Spread the black bean mixture on the toast.",
    "Garnish with chopped fresh parsley.",
    "Serve warm and enjoy."
  ],
