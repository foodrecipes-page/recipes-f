      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "water",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the olive oil in a wok over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for another minute.",
    "Add the cumin, coriander, salt, and black pepper, and stir well.",
    "Add the chopped cassaba and stir to coat with the spice mixture.",
    "Add the malt syrup and water, and bring to a boil.",
    "Reduce the heat to low and simmer for 20 minutes.",
    "Serve hot and enjoy."
  ],
