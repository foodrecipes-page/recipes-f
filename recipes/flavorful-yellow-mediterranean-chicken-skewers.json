  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "lemon juice",
      "amount": "1/4 cup"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "4 cloves",
      "notes": "minced"
    },
    {
      "name": "yellow food colouring",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "dried oregano",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "wooden skewers",
      "amount": "10",
      "notes": "soaked in water for 30 minutes"
    }
  ],
  "instructions": [
    "Preheat the robata-grill to medium-high heat.",
    "In a large bowl, whisk together lemon juice, olive oil, garlic, yellow food colouring, dried oregano, salt, and pepper.",
    "Add the chicken to the bowl and toss to coat with the marinade.",
    "Thread the marinated chicken onto the soaked wooden skewers, leaving a small space between each piece.",
    "Brush the grill with olive oil to prevent sticking.",
    "Grill the chicken skewers for 8-10 minutes, turning occasionally, until cooked through.",
    "Serve the chicken skewers hot, garnished with fresh parsley or oregano if desired."
  ],
