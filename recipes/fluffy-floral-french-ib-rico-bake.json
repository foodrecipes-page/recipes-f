  "instructions": [
    "Preheat the oven to 180°C.",
    "Grease a baking dish with butter.",
    "Mix together flour and baking powder.",
    "Add the sugar and lemon zest to the dry mixture and mix until combined.",
    "Beat the egg and mix with the almond milk and vanilla extract.",
    "Pour the wet ingredients into the dry mixture and stir until just combined.",
    "Gently fold in the IB Rico and jam.",
    "Pour the batter into the prepared baking dish.",
    "Smooth the top and bake for 35 minutes.",
    "Remove from the oven and let cool for 5 minutes before serving."
