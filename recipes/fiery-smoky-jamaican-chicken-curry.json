{
  "title": "Fiery Smoky Jamaican Chicken Curry",
  "description": "A spicy and smoky chicken curry dish featuring Jamaican flavors, perfect for a monsoon day. This dairy-free friendly recipe is made with shio-koji cure and smoky oil.",
  "cuisine": "Jamaican",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "smoky oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "shio-koji",
      "amount": "1 tablespoon"
    },
    {
      "name": "curry powder",
      "amount": "2 teaspoons"
    },
    {
      "name": "scotch bonnet peppers",
      "amount": "2",
      "notes": "seeded and chopped"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat the smoky oil in a large pan over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the chicken breast pieces and cook until browned, about 5 minutes.",
    "Add the curry powder, shio-koji, and scotch bonnet peppers, and cook for 1 minute.",
    "Pour in the coconut milk and bring the mixture to a simmer.",
    "Reduce the heat to low and let cook for 20 minutes, or until the chicken is cooked through.",
    "Season with salt to taste.",
    "Serve hot over rice or with roti.",
    "Garnish with chopped fresh cilantro, if desired."
  ],
