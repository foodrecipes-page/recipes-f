{
  "title": "fatty velvety syrian tomatoes bake",
  "description": "a low-carb-friendly, weeknight syrian dish featuring baby plum tomatoes, reduced to create a rich and velvety texture",
  "cuisine": "syrian",
  "diet": [],
  "meal": "dinner",
  "ingredients": [
