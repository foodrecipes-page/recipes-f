  "instructions": [
    "preheat oven to 375°f",
    "in a large bowl, combine the baby plum tomatoes, onion, garlic, allspice, cumin, salt, and black pepper",
    "mix well to combine",
    "transfer the mixture to a baking dish and drizzle with olive oil",
    "dot the top with butter",
    "cover the dish with aluminum foil and bake for 25 minutes",
    "remove the foil and continue baking for an additional 15-20 minutes, or until the tomatoes are tender and the sauce has thickened",
    "stir in the creme fraiche and heavy cream",
    "top with parmesan cheese and fresh parsley",
    "return to the oven and bake for an additional 2-3 minutes, or until the cheese is melted and bubbly",
    "remove from the oven and serve hot"
  ],
