    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "coriander seeds",
      "amount": "2 tablespoons"
    },
    {
      "name": " Arborio rice",
      "amount": "1 cup"
    },
    {
      "name": "khao khuat",
      "amount": "1 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "grated Parmesan cheese",
      "amount": "1/2 cup"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium-high heat.",
    "Add the chicken to the skillet and cook until browned, about 5 minutes.",
    "Add the coriander seeds to the skillet and cook for 1 minute.",
    "Add the Arborio rice and khao khuat to the skillet, stirring to combine.",
    "Cook for 2 minutes, stirring constantly.",
    "Add the chicken broth to the skillet, 1/2 cup at a time, stirring constantly and allowing each portion to absorb before adding the next.",
    "Stir in the salt and black pepper.",
    "Reduce heat to low, cover, and simmer for 20 minutes.",
    "Stir in the grated Parmesan cheese.",
    "Garnish with chopped fresh parsley."
  ],
