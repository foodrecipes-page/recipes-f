      "name": "epoisses cheese",
      "amount": "1 cup",
      "notes": "crumbly"
    },
    {
      "name": "miso paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "thai red curry paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "fish sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "lime juice",
      "amount": "1 tablespoon"
    },
    {
