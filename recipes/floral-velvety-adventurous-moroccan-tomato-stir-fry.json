{
  "title": "Floral Velvety Adventurous Moroccan Tomato Stir-fry",
  "description": "A diabetic-friendly Moroccan tomato dish featuring floral flavors from pickle juice and a velvety texture with bhuna spices.",
  "cuisine": "Moroccan",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "tomatoes",
      "amount": "2 cups",
      "notes": "chopped"
    },
    {
      "name": "pickled vegetables",
      "amount": "1/4 cup",
      "notes": "juice only"
    },
    {
      "name": "bhuna spices",
      "amount": "1 tsp",
      "notes": "mixed finely with other spices for a blend"
    },
    {
      "name": "diabetic-friendly tomato sauce",
      "amount": "1/2 cup",
      "notes": "reduced sugar, no added salt"
    },
    {
      "name": "olive oil",
      "amount": "3 tbsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "pepper",
      "amount": "to taste"
    },
    {
      "name": "cilantro leaves",
      "amount": "1/4 cup",
      "notes": "for garnish"
    }
  ],
  "instructions": [
    "Heat olive oil in a wok or large frying pan over medium-high heat.",
    "Add chopped tomatoes and bhuna spices, sauté for about 5 minutes until soft and slightly caramelized.",
    "Stir in pickled vegetable juice and tomato sauce. Reduce the heat to low-medium and simmer for another 10-15 minutes.",
    "Season with salt and pepper to taste.",
    "Garnish with cilantro leaves before serving."
  ],
