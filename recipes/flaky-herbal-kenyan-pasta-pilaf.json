      "notes": "dried, preferably Kenyan brand"
    },
    {
      "name": "water",
      "amount": "2 cups",
      "notes": "for cooking pasta and making emulsion"
    },
    {
      "name": "muscovado sugar",
      "amount": "2 tablespoons",
      "notes": "adds a hint of sweetness"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons",
      "notes": "for flavor and moisture"
    },
    {
      "name": "chopped scallions",
      "amount": "1/2 cup",
      "notes": "for garnish and flavor"
    },
    {
      "name": "herbs (such as parsley, basil, or cilantro)",
      "amount": "1/4 cup",
      "notes": "chopped, for flavor and texture"
    },
    {
      "name": "coconut oil",
      "amount": "2 tablespoons",
      "notes": "for cooking and flavor"
    },
    {
      "name": "diced ginger",
      "amount": "1 tablespoon",
      "notes": "for flavor and anti-inflammatory properties"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon",
      "notes": "for flavor"
    },
    {
      "name": "salt",
      "amount": "to taste",
      "notes": "for seasoning"
    }
  ],
  "instructions": [
    "Heat coconut oil in a large talavera plate over medium heat.",
    "Add diced ginger and cook for 1 minute, until fragrant.",
    "Add ground cumin and cook for 1 minute, until fragrant.",
    "Add pasta, water, muscovado sugar, and lemon juice. Bring to a boil, then reduce heat to low and simmer for 10 minutes, until pasta is cooked and liquid has reduced.",
    "Stir in chopped scallions and herbs. Cook for 1 minute, until wilted.",
    "Season with salt to taste.",
    "Serve hot, garnished with additional scallions and herbs if desired."
  ],
