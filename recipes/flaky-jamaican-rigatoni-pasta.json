      "amount": "12 oz",
      "notes": "gluten-free"
    },
    {
      "name": "coconut milk",
      "amount": "1 can (14 oz)"
    },
    {
      "name": "jerk seasoning",
      "amount": "2 tbsp"
    },
    {
      "name": "curry powder",
      "amount": "1 tsp"
    },
    {
      "name": "thyme",
      "amount": "1 tsp",
      "notes": "fresh"
    },
    {
      "name": "scotch bonnet peppers",
      "amount": "2",
      "notes": "seeded and chopped"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium heat.",
    "Add chopped onion and cook until translucent, about 5 minutes.",
    "Add minced garlic and cook for an additional minute.",
    "Add jerk seasoning, curry powder, and thyme. Cook for 1 minute, stirring constantly.",
    "Add chopped scotch bonnet peppers and cook for 2 minutes.",
    "Add rigatoni to the skillet, stirring to combine with the spice mixture.",
    "Pour in coconut milk and bring to a simmer.",
    "Reduce heat to low and let cook, covered, for 20-25 minutes or until the rigatoni is al dente.",
    "Season with salt to taste.",
    "Serve hot, garnished with fresh thyme if desired."
  ],
