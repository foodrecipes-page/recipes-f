  "instructions": [
    "heat the olive oil in a large clay pot over medium heat.",
    "saute the onion and garlic until the onion is translucent.",
    "add the cumin, coriander, turmeric, and paprika and stir for 1 minute.",
    "add the chives and saute for 2 minutes.",
    "add the flour and stir to combine.",
    "slowly add the chicken broth and bring to a boil.",
    "reduce the heat to low and simmer for 10 minutes.",
    "ignite the dish with a flambe of lemon juice and serve hot.",
    "garnish with additional chives if desired."
