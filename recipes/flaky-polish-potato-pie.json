  "ingredients": [
    {
      "name": "potato",
      "amount": "1 large",
      "notes": "washed, peeled, thinly sliced"
    },
    {
      "name": "butter",
      "amount": "2 tbsp",
      "notes": "cold, cubed"
    },
    {
      "name": "flour",
      "amount": "1/4 cup",
      "notes": "all-purpose"
    },
    {
      "name": "water",
      "amount": "1/4 cup",
      "notes": "cold"
    },
    {
      "name": "pico de gallo",
      "amount": "1/2 cup",
      "notes": "fresh, finely chopped"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "In a bowl, mix butter and flour until crumbly.",
    "Add water and knead until dough forms a ball.",
    "Roll dough thin and place potatoes on top.",
    "Layer pico de gallo over potatoes.",
    "Press edges to seal and cut 1-inch slits for steam.",
    "Bake for 25 minutes until golden and flaky.",
    "Let rest for 5 minutes before serving."
  ],
