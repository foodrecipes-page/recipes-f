      "name": "Braeburn apples",
      "amount": "2 (medium-sized)"
    },
    {
      "name": "Coconut oil",
      "amount": "1 tbsp"
    },
    {
      "name": "Cinnamon powder",
      "amount": "1/2 tsp"
    },
    {
      "name": "All-purpose flour",
      "amount": "1 tbsp"
    },
    {
      "name": "Vanilla extract",
      "amount": "1/4 tsp"
    },
    {
      "name": "Sugar substitute (like erythritol or stevia)",
      "amount": "1 tbsp"
    }
  ],
  "instructions": [
    "Preheat your oven to 350°F.",
    "Wash and slice the Braeburn apples into thin rounds. Arrange them in a baking dish.",
    "Mix together coconut oil, cinnamon powder, all-purpose flour, vanilla extract, and sugar substitute until well combined.",
    "Pour the mixture evenly over the sliced apples.",
    "Bake for 15 minutes or until the topping is golden brown and the apples are tender but not mushy.",
    "Serve warm as a dessert."
  ],
