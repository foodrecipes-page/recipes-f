{
  "title": "Floral Gooey Saudia Apple Stir-fry",
  "description": "A floral and gooey low-carb-friendly Saudi Arabian dish featuring Braeburn apples baked to perfection.",
  "cuisine": "Saudi Arabian",
  "diet": [
