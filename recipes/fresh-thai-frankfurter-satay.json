      "amount": "1 tsp"
    },
    {
      "name": "Pepper",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat the broiler to 400 degrees Fahrenheit.",
    "Thread the sliced frankfurters onto the wooden skewers.",
    "In a large bowl, whisk together peanut oil, lemongrass, galangal, kaffir lime leaves, Thai red curry paste, coconut milk, salt, and pepper.",
    "Add the skewers to the bowl and marinate for 10 minutes.",
    "Place the skewers on a wooden board and broil for 5 minutes per side.",
    "Serve hot on the wooden board.",
    "Garnish with additional kaffir lime leaves and lemongrass if desired."
  ],
