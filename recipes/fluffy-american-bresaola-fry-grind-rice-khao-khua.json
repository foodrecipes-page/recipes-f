{
  "title": "Fluffy American Bresaola Fry-Grind-Rice-Khao-Khua",
  "description": "A festive and healthy American dish featuring bresaola, fry-grind-rice-khao-khua.",
  "cuisine": "American",
  "diet": [
    "low-glycemic",
