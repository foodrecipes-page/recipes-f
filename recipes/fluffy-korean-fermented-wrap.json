  "instructions": [
    "rinse the corn husks in cold water, pat dry with a paper towel",
    "cook the brown rice according to package instructions",
    "mix the namul-blanch-season with 1 tablespoon of water",
    "chop the parsley and set aside",
    "layer the kimchi and brown rice in the center of each corn husk wrap",
    "sprinkle the matcha powder on top, if using",
    "fold the bottom of the corn husk up over the filling, then fold in the sides and roll up the wrap",
    "place the wraps seam-side down on a baking sheet and refrigerate for at least 2 hours to ferment"
