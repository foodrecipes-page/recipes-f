      "name": "kabanos sausages",
      "amount": "12",
      "notes": "sliced into 1 inch pieces"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "honey",
      "amount": "1 tablespoon"
    },
    {
      "name": "grated ginger",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "Thai basil",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "cedar planks",
      "amount": "4",
      "notes": "soaked in water for 30 minutes"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat.",
    "In a large bowl, whisk together coconut milk, fish sauce, lime juice, honey, grated ginger, and garlic.",
    "Add the sliced kabanos sausages to the bowl and marinate for at least 30 minutes.",
    "Thread the marinated sausage pieces onto skewers, leaving a small space between each piece.",
    "Place the skewers on the soaked cedar planks.",
    "Grill the skewers for 8-10 minutes, turning occasionally, until the sausages are cooked through.",
    "Garnish with chopped Thai basil and serve immediately."
  ],
