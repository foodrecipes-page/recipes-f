{
  "title": "Fermented Pillowy Algerian Fish Tagine",
  "description": "A pescatarian-friendly, fermented, pillowy Algerian dish featuring juniper berries, perfect for hangover relief. Serve over fluffy couscous. ",
  "cuisine": "Algerian",
  "diet": [
    "pescatarian"
