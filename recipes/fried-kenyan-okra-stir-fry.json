    {
      "name": "Sunflower Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Red Pepper Flakes",
      "amount": "a small pinch for seasoning"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "Cilantro",
      "amount": "1 tablespoon chopped fresh (optional garnish)"
    }
  ],
  "instructions": [
    "Heat sunflower oil in a non-stick skillet over medium-high heat.",
    "Add the minced garlic and cook for about 30 seconds until fragrant, being careful not to burn it.",
    "Add the okra and sprinkle with red pepper flakes. Stir continuously for about 5 minutes or until the okra turns golden brown and crispy on the edges.",
    "Remove from heat and serve hot with a sprinkle of chopped cilantro if desired."
  ],
