{
  "title": "Floral Crumbly Filipino Cabbage Casserole",
  "description": "A comforting onepot Filipino casserole that marries the floral aroma of star anise and cinnamon with crumbly, golden breadcrumbs atop tender shredded cabbage.",
  "cuisine": "Filipino",
  "diet": [
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "white cabbage",
      "amount": "1 medium head (\u22481.5\u202fkg)",
      "notes": "shredded"
    },
    {
      "name": "unsalted butter",
      "amount": "2\u202ftbsp"
    },
    {
      "name": "onion",
      "amount": "1 medium, finely chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "star anise",
      "amount": "1\u202ftsp",
      "notes": "floral note"
    },
    {
      "name": "ground cinnamon",
      "amount": "\u00bd\u202ftsp"
    },
    {
      "name": "fish sauce (patis)",
      "amount": "2\u202ftbsp"
    },
    {
      "name": "brown sugar",
      "amount": "1\u202ftbsp"
    },
    {
      "name": "coconut milk",
      "amount": "\u00bd\u202fcup"
    },
    {
      "name": "breadcrumbs",
      "amount": "\u00bd\u202fcup"
    },
    {
      "name": "grated Parmesan cheese",
      "amount": "\u00bc\u202fcup"
    },
    {
      "name": "fresh basil",
      "amount": "1\u202ftbsp",
      "notes": "optional garnish"
    }
  ],
  "instructions": [
    "Preheat oven to 180\u202f\u00b0C (350\u202f\u00b0F) and lightly butter a 2\u2011quart baking dish.",
    "Melt butter in a large skillet over medium heat; saut\u00e9 onion, garlic, star anise, and cinnamon until fragrant, about 3\u202fmin. Remove star anise.",
    "Add shredded cabbage and cook, stirring, until just wilted, about 5\u202fmin.",
    "Stir in fish sauce, brown sugar, and coconut milk; cook for 2\u202fmin until combined.",
    "Transfer cabbage mixture to the prepared baking dish, spreading evenly.",
    "In a small bowl mix breadcrumbs, Parmesan, and a pinch of salt; sprinkle over the cabbage.",
    "Bake uncovered for 20\u201325\u202fmin, or until the topping is golden and the cabbage tender.",
    "Let rest 5\u202fmin, garnish with fresh basil if desired, and serve hot."
  ],
