      "name": "onions",
      "amount": "1 large",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat.",
    "In a large bowl, whisk together olive oil, lemon juice, garlic, ginger, cayenne pepper, salt, and black pepper.",
    "Add the onion pieces to the bowl and toss to coat with the marinade.",
    "Thread the marinated onions onto skewers, leaving a small space between each piece.",
    "Grill the skewers for 8-10 minutes, turning occasionally, until the onions are tender and lightly charred.",
    "Garnish with chopped fresh parsley and serve hot."
  ],
