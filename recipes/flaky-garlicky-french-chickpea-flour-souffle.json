{
  "title": "Flaky Garlicky French Chickpea Flour Souffle",
  "description": "A delicious, flaky, garlicky souffle made with chickpea flour, perfect for brunch or a light dinner. Serve in a stone bowl for a fun presentation.",
  "cuisine": "French",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],
