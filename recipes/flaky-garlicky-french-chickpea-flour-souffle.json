  "ingredients": [
    {
      "name": "chickpea flour",
      "amount": "1 1/2 cups",
      "notes": "sifted"
    },
    {
      "name": "unsalted butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "nutritional yeast",
      "amount": "2 tablespoons",
      "notes": "dried"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon",
      "notes": ""
    },
    {
      "name": "black pepper",
      "amount": "1/8 teaspoon",
      "notes": ""
    },
    {
      "name": "water",
      "amount": "3/4 cup",
      "notes": ""
    },
    {
      "name": "eggs",
      "amount": "2",
      "notes": "beaten"
    },
    {
      "name": "grated cheddar",
      "amount": "1/4 cup",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "Sift the chickpea flour into a large bowl.",
    "Add the melted butter, garlic, nutritional yeast, salt, and pepper to the bowl and stir to combine.",
    "Gradually add the water to the bowl, stirring to form a smooth batter.",
    "Beat in the eggs until well combined.",
    "Pour the batter into a buttered 6-cup souffle dish or a 9x13-inch baking dish.",
    "Sprinkle the grated cheddar on top, if using.",
    "Bake for 25-30 minutes, or until the souffle is puffed and golden brown.",
    "Serve immediately, garnished with chopped fresh herbs if desired."
  ],
