{
  "title": "Fluffy Greek Yogurt Casserole",
  "description": "A tangy, fluffy breakfast casserole with a lightly caramelized honeyolive oil topping thats both energizing and lowcalorie.",
  "cuisine": "Greek",
  "diet": [
    "vegetarian"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "nonfat Greek yogurt",
      "amount": "200g",
      "notes": "about 1 cup"
    },
    {
      "name": "large eggs",
      "amount": "2",
      "notes": "room temperature"
    },
    {
      "name": "honey",
      "amount": "1 tablespoon",
      "notes": "for batter"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon",
      "notes": "optional"
    },
    {
      "name": "baking soda",
      "amount": "1/2 teaspoon",
      "notes": "leavening"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon",
      "notes": "optional"
    },
    {
      "name": "walnuts, chopped",
      "amount": "50g",
      "notes": "optional for crunch"
    },
    {
      "name": "unsweetened applesauce",
      "amount": "1 tablespoon",
