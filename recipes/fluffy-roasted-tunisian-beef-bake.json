{
  "title": "Fluffy Roasted Tunisian Beef Bake",
  "description": "A light and flavorful dish with a fluffy texture, featuring hot beef stock and an en-croute style. Jain-friendly and perfect for a weeknight dinner.",
  "cuisine": "tunisian",
