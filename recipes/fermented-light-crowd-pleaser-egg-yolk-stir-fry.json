    {
      "name": "2 tablespoons fermented black beans",
      "amount": "tablespoons"
    },
    {
      "name": "Juice of 3 limes",
      "amount": "juice"
    },
    {
      "name": "2 cloves garlic, minced",
      "amount": "cloves"
    },
    {
      "name": "1 red bell pepper, julienned",
      "amount": "piece"
    },
