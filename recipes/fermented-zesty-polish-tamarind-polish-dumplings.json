{
  "title": "Fermented Zesty Polish Tamarind Polish Dumplings",
  "description": "A traditional Polish dish with a fermented twist, featuring tamarind paste and kimchi. Best served on a sick day.",
  "cuisine": "Polish",
  "diet": [
    "gluten-free",
    "sugar-free"
